# =============================================================================
# AI Provider
# =============================================================================
# GitHub Models API is FREE for all GitHub accounts. No paid API key needed.
# All models (Claude, GPT, Llama) are available through the same GitHub token.
# =============================================================================
AI_PROVIDER=github-models

# GitHub Personal Access Token (FREE)
# Create at: https://github.com/settings/tokens → classic token → no scopes needed
GITHUB_TOKEN=ghp_xxxxx

# AI Model — available models via GitHub Models API (all free):
#
#   OpenAI:
#     openai/gpt-5               — Best OpenAI model
#     openai/gpt-4.1             — Great at coding and long context
#     gpt-4o                     — Good general purpose (note: no openai/ prefix)
#     gpt-4o-mini                — Good, higher rate limits
#
#   Anthropic (Claude) via GitHub Models:
#     anthropic/claude-4-opus    — Best Claude model (tested: unreliable via GitHub Models)
#     anthropic/claude-4-sonnet  — Great, faster (tested: unreliable via GitHub Models)
#     NOTE: Claude models via GitHub Models did not work reliably in our testing.
#           If you want Claude, use the Anthropic API directly (see below).
#
#   Other:
#     meta/llama-4-scout         — Good, open-source
#     deepseek/deepseek-r1       — Good, reasoning
#
# Note: model IDs vary — some have vendor prefix, some don't.
# Check https://github.com/marketplace?type=models for the latest list.
AI_MODEL=openai/gpt-4.1

# Max tokens for AI response (4096 is usually enough)
AI_MAX_TOKENS=4096

# --- Alternative: Anthropic API (pay-per-use, no rate limits) ---
# Uncomment and set AI_PROVIDER=claude if you want to use the Anthropic API directly
# ANTHROPIC_API_KEY=sk-ant-xxxxx   # Get from https://console.anthropic.com
# AI_MODEL=claude-sonnet-4-6

# --- Alternative: OpenAI API (pay-per-use, no rate limits) ---
# Uncomment and set AI_PROVIDER=openai if you want to use the OpenAI API directly
# OPENAI_API_KEY=sk-xxxxx          # Get from https://platform.openai.com
# AI_MODEL=gpt-4o

# --- Alternative: Claude CLI (no API keys needed) ---
# If you have the `claude` CLI (Claude Code) authenticated, you can skip API keys entirely.
# Use the standalone scripts: ./scripts/cli-preview.sh or .\scripts\cli-preview.ps1
# Or import workflows/cli-preview-pipeline.json into n8n (requires native n8n, not Docker).
# The CLI uses whatever model your Claude Code subscription provides (e.g., claude-opus-4-6).

# =============================================================================
# Confluence Configuration
# =============================================================================
# Base URL: your Atlassian instance (no trailing slash)
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net

# Your Atlassian account email
CONFLUENCE_EMAIL=your-email@company.com

# API token (NOT your password): https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-confluence-api-token

# Space key: visible in URL → https://yourcompany.atlassian.net/wiki/spaces/TECH/...
CONFLUENCE_SPACE_KEY=TECH

# Optional: nest generated pages under a specific parent page
CONFLUENCE_PARENT_PAGE_ID=

# Optional: Confluence macro used to render ```mermaid blocks. Default 'mermaid-cloud'
# (the free "Mermaid Diagrams for Confluence" app). The diagram source is stored in the
# macro body either way, so it renders if the app is installed and always round-trips back
# to a ```mermaid fence on pull. Jira renders mermaid as a code block (language=mermaid).
CONFLUENCE_MERMAID_MACRO=mermaid-cloud

# =============================================================================
# Jira Configuration (optional — skip if not creating tickets)
# =============================================================================
# Same Atlassian instance and credentials as Confluence
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# Project key: visible in ticket IDs like PROJ-123
JIRA_PROJECT_KEY=PROJ

# Defaults for created tickets (change to match your Jira setup)
JIRA_DEFAULT_ASSIGNEE=
JIRA_DEFAULT_PRIORITY=Medium
JIRA_DEFAULT_COMPONENT=
# ^ Set this if your Jira project requires a component on every issue.
#   Use the exact component name from Jira (e.g., "Backend", "Frontend").
#   Can be overridden per-issue via ## Component in the markdown.
JIRA_EPIC_ISSUE_TYPE=Epic
JIRA_STORY_ISSUE_TYPE=Story
JIRA_SUBTASK_ISSUE_TYPE=Sub-task

# =============================================================================
# n8n Configuration
# =============================================================================
N8N_PORT=10353
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-this-to-a-random-string
WEBHOOK_URL=http://localhost:10353/webhook
