{
  "name": "katastasi",
  "version": "0.4.0",
  "description": "Katastasi — open-source documentation, task-tracking, and testing framework. Local-first markdown source of truth; agent-native (MCP); syncs to Jira/Confluence/issues/CI. Answers: what is the real status — is this actually done and verified?",
  "license": "MIT",
  "type": "module",
  "bin": {
    "katastasi": "dist/cli/index.js",
    "kat": "dist/cli/index.js",
    "acp": "dist/cli/index.js",
    "katastasi-mcp": "dist/mcp/server.js",
    "acp-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "VISION.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmindednewby/katastasi.git"
  },
  "homepage": "https://github.com/openmindednewby/katastasi#readme",
  "bugs": {
    "url": "https://github.com/openmindednewby/katastasi/issues"
  },
  "keywords": [
    "requirements",
    "traceability",
    "rtm",
    "testing",
    "task-tracking",
    "documentation",
    "jira",
    "confluence",
    "mcp",
    "ai-agents",
    "ci",
    "markdown"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsc -p tsconfig.json --watch",
    "start:mcp": "node dist/mcp/server.js",
    "deploy:workflows": "node scripts/deploy-workflows.mjs",
    "docker:build": "bash scripts/docker-build.sh",
    "docker:deploy": "bash scripts/docker-deploy-remote.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test",
    "publish:both": "bash scripts/publish-npm.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0"
  }
}
